# CALM — Biến môi trường mẫu
# Sao chép thành .env và điền giá trị thực (không commit .env lên Git).

# Bắt buộc: ít nhất một trong hai key để gọi LLM
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...

# Tùy chọn: Google Earth Engine
# GEE_PROJECT_ID=your-gee-project-id

# Tùy chọn: Copernicus CDS (ERA5)
# COPERNICUS_API_KEY=your-cds-api-key

# Tùy chọn: thư mục gốc dự án (để load .env khi chạy từ nơi khác)
# CALM_ROOT=/path/to/calm
